        "kind": "agentTurn",
        "message": "Generate a science and space news bulletin covering the top 8 most important stories from the last 48 hours. Sources: Nature, Science, NASA, ESA, Space.com, New Scientist, Phys.org, Scientific American.\n\nOutput ONLY the bulletin in this exact format:\n**Title:** ...\n**Summary:** (10-word summary)\n**Link:** ...\n\nInclude: Space missions, astronomy, physics, biology, climate science, medical research, technology breakthroughs.\nExclude: Politics, sports, entertainment.\n\nSkip all narration. Just output the compiled bulletin.",
        "model": "opencode-zen/glm-5-free",
        "thinking": "off",
        "timeoutSeconds": 600
      },
      "delivery": {
        "bestEffort": true,
        "channel": "telegram",
        "mode": "announce",
        "to": "YOUR_CHAT_ID"
      }
