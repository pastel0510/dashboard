    {
      "id": "fcc3bc5b-b36f-4a5e-9a65-21bfc8c6UUID",
      "agentId": "main",
      "name": "Science & Space News Bulletin (daily 17:02 UTC+2)",
      "enabled": true,
      "createdAtMs": 1771522691608,
      "updatedAtMs": 1771632717279,
