    {
      "id": "89f4721b-6574-47c4-8a11-4dbe22d44UUID",
      "agentId": "main",
      "name": "Self‑reflection & improvement log",
      "enabled": true,
      "createdAtMs": 1771254755586,
      "updatedAtMs": 1771632353559,
      "schedule": {
        "expr": "0 */3 * * *",
        "kind": "cron",
        "staggerMs": 300000
      },
      "sessionTarget": "isolated",
      "wakeMode": "now",
      "payload": {
        "kind": "agentTurn",
        "message": "Please review the last 6 hours of this session's messages, identify any mistakes (e.g., inaccurate info, formatting issues, failed tool calls). If mistakes are found, append a concise summary to MEMORY.md under a \"## Reflections\" heading. If no mistakes are found, do nothing — do not send any message or announcement.",
        "model": "opencode-zen/glm-5-free",
        "thinking": "off",
        "timeoutSeconds": 300
      },
      "delivery": {
        "mode": "none",
        "channel": "telegram",
        "to": "YOUR_CHAT_ID",
        "bestEffort": true
      }
    },
    {
      "id": "01feffa5-5573-4e34-8389-630e2ad5UUID",
      "agentId": "main",
      "name": "Security Bulletin (Mon 7:50 UTC+2 – last 72 h)",
      "enabled": true,
