        "kind": "agentTurn",
        "message": "Generate a Finnish news bulletin covering the top 8 most important stories from the last 24 hours. Sources: YLE, Helsingin Sanomat, Turun Sanomat, Iltalehti, Ilta-Sanomat, Kauppalehti.\n\nOutput ONLY the bulletin in this exact format:\n**Title:** ...\n**Summary:** (10-word summary)\n**Link:** ...\n\nOnly include general news (politics, economy, society, culture, weather). NO sports, cybersecurity, or IT security topics.\n\nSkip all narration. Just output the compiled bulletin.",
        "model": "opencode-zen/glm-5-free",
        "thinking": "off",
        "timeoutSeconds": 600
      },
      "delivery": {
        "mode": "announce",
        "channel": "telegram",
        "to": "YOUR_CHAT_ID",
        "bestEffort": true
      }
