      "agentId": "main",
      "name": "Finnish News Bulletin (daily 17:00 UTC+2)",
      "enabled": true,
      "createdAtMs": 1771517731167,
      "updatedAtMs": 1771632713532,
      "schedule": {
        "kind": "cron",
        "expr": "0 15 * * *",
